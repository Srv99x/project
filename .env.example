# -------------------------------
# NeuroNex Global Environment File
# -------------------------------
# Copy this file to .env and set real values.
# This root .env is used by both:
# 1) Vite frontend (for VITE_* vars and build-time constants)
# 2) FastAPI backend (auto-loaded in backend/main.py)

# Frontend / AI
VITE_GEMINI_API_KEY=
VITE_API_BASE_URL=

# Backend CORS
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Backend code execution timeout
CODE_EXEC_TIMEOUT=15

# onlinecompiler.io provider config
ONLINECOMPILER_API_URL=https://api.onlinecompiler.io/api/run-code-sync/
ONLINECOMPILER_API_KEY=
